{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "SpotifyProj1-DataFactory"
		},
		"AzureSqlProj1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlProj1'"
		},
		"DataLake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DataLake'"
		},
		"AzureSqlProj1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "spotifyproj1-sqlserver.database.windows.net"
		},
		"AzureSqlProj1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adminraman"
		},
		"AzureSqlProj1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "CloudSAfa229c13"
		},
		"DataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifyproj1storageacc.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "SpotifyProj1-DataFactory_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSqlProj1_password": {
						"value": "[parameters('AzureSqlProj1_password')]"
					},
					"DataLake_accountKey": {
						"value": "[parameters('DataLake_accountKey')]"
					},
					"AzureSqlProj1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlProj1_properties_typeProperties_server')]"
					},
					"AzureSqlProj1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlProj1_properties_typeProperties_database')]"
					},
					"AzureSqlProj1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlProj1_properties_typeProperties_userName')]"
					},
					"DataLake_properties_typeProperties_url": {
						"value": "[parameters('DataLake_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}